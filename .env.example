# ==========================================
# AMPM LENDING - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env.local for local development
# Copy this file to .env for Docker / production

# ------------------------------------------
# DATABASE (Neon PostgreSQL)
# ------------------------------------------
# Get from: https://neon.tech → Create project → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://ampm_user:your_password@your-neon-host.neon.tech/ampm_lending?sslmode=require"

# Prisma direct URL (for migrations, bypasses connection pooler)
DIRECT_URL="postgresql://ampm_user:your_password@your-neon-host.neon.tech/ampm_lending?sslmode=require"

# ------------------------------------------
# NEXTAUTH / AUTH.JS
# ------------------------------------------
# Generate with: openssl rand -base64 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="replace_with_your_generated_64_char_secret"

# Your production URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------
# GOOGLE OAUTH
# ------------------------------------------
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your_google_oauth_client_id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# ------------------------------------------
# EMAIL (SMTP / Nodemailer)
# ------------------------------------------
# Option A: Gmail with App Password (recommended for small-scale)
#   Enable 2FA → Google Account → App Passwords → Generate
# Option B: SendGrid / Mailgun / Resend for high volume
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASSWORD="your_gmail_app_password_16_chars"

# From address displayed in emails
EMAIL_FROM="AMPM Lending <noreply@your-domain.com>"
EMAIL_FROM_NAME="AMPM Lending"

# ------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AMPM Lending"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ------------------------------------------
# SECURITY
# ------------------------------------------
# Rate limiting: max login attempts before lockout
MAX_LOGIN_ATTEMPTS="5"
# Lockout duration in minutes
LOGIN_LOCKOUT_MINUTES="15"
# Temporary password expiry in hours
TEMP_PASSWORD_EXPIRY_HOURS="48"

# ------------------------------------------
# REDIS (Optional - for background jobs / rate limiting)
# ------------------------------------------
# REDIS_URL="redis://localhost:6379"

# ------------------------------------------
# NODE ENVIRONMENT
# ------------------------------------------
NODE_ENV="development"
