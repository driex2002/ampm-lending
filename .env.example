# ==========================================
# AMPM LENDING - ENVIRONMENT CONFIGURATION
# ==========================================
# HOW TO USE:
#   Docker (recommended): Copy this file to .env in the project root.
#     The docker-compose.yml reads variables directly from .env.
#   Local development:    Copy this file to .env.local instead.
#
# MINIMUM REQUIRED for Docker deployment:
#   NEXTAUTH_SECRET  — must be set; app will warn but still start without it,
#                      however sessions will be insecure.
#   DATABASE_URL / DIRECT_URL are pre-configured for the bundled Postgres
#   container and do NOT need to be changed for local Docker usage.
#
# FIRST-TIME SETUP (Docker):
#   1. cp .env.example .env
#   2. Set NEXTAUTH_SECRET (see instructions below)
#   3. docker compose up -d
#   4. docker exec ampm-app node ./node_modules/prisma/build/index.js db seed
#      (creates the default admin account — see seed.ts for credentials)

# ------------------------------------------
# DATABASE
# ------------------------------------------
# Default values match the bundled postgres container in docker-compose.yml.
# Change only if you are pointing to an external/cloud database.
DATABASE_URL="postgresql://ampm:ampm_password@postgres:5432/ampm_lending?schema=public"
DIRECT_URL="postgresql://ampm:ampm_password@postgres:5432/ampm_lending?schema=public"

# ------------------------------------------
# NEXTAUTH / AUTH.JS
# ------------------------------------------
# Generate with: openssl rand -base64 32
# Or in PowerShell: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))
# Or in Node.js:   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# IMPORTANT: docker-compose.yml reads NEXTAUTH_SECRET (not AUTH_SECRET).
# Make sure you use the correct name when creating your .env file.
NEXTAUTH_SECRET="replace_with_your_generated_secret"

# Your production URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------
# GOOGLE OAUTH (optional)
# ------------------------------------------
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# Note: docker-compose.yml reads GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET.
# Leave blank ("") to disable Google login.
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# ------------------------------------------
# EMAIL (Gmail SMTP via Nodemailer)
# ------------------------------------------
# Enable 2-Step Verification on your Gmail account, then:
#   Google Account → Security → App Passwords → Generate a 16-character password
# Note: docker-compose.yml reads GMAIL_USER and GMAIL_APP_PASSWORD.
# Leave blank ("") to disable email notifications.
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your_gmail_app_password_16_chars"

# Sender name shown in outgoing emails
EMAIL_FROM_NAME="AMPM Lending"

# ------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AMPM Lending"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ------------------------------------------
# SECURITY
# ------------------------------------------
# Rate limiting: max login attempts before lockout
MAX_LOGIN_ATTEMPTS="5"
# Lockout duration in minutes
LOGIN_LOCKOUT_MINUTES="15"
# Temporary password expiry in hours
TEMP_PASSWORD_EXPIRY_HOURS="48"

# ------------------------------------------
# REDIS (Optional - for background jobs / rate limiting)
# ------------------------------------------
# REDIS_URL="redis://localhost:6379"

# ------------------------------------------
# NODE ENVIRONMENT
# ------------------------------------------
NODE_ENV="development"
